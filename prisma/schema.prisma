generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  userAgent    String?
  ipAddress    String?
  location     String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                          String                @id @default(uuid())
  name                        String?
  email                       String?               @unique
  emailVerified               DateTime?
  image                       String?
  role                        String                @default("CANDIDATE")
  createdAt                   DateTime              @default(now())
  onboardedAt                 DateTime?
  companyId                   String?
  bio                         String?
  headline                    String?
  skills                      String?
  github                      String?
  linkedin                    String?
  location                    String?
  password                    String?
  portfolio                   String?
  username                    String?               @unique
  bannerUrl                   String?
  customLinks                 String?
  resumeUrl                   String?
  ghostMode                   Boolean               @default(false)
  nodeType                    String                @default("OPEN") // OPEN, BROADCAST
  emailNotifications          Boolean               @default(true)
  marketingEmails             Boolean               @default(false)
  notificationMutedGroups     String[]              @default([]) // in-app notification groups the user muted
  lastNotificationEmailSentAt DateTime?
  lastLogin                   DateTime?
  credits                     Int                   @default(10) // LEGACY single-bucket — kept for back-compat; superseded by the 3 buckets below
  // Three-bucket credit system (2026-06): plan buckets reset monthly; topUp is permanent.
  resumeCredits               Int                   @default(3)  // AI Resume → Profile builder
  interviewCredits            Int                   @default(3)  // AI Interview
  generalCredits              Int                   @default(4)  // usable anywhere incl. accepting bookings
  topUpCredits                Int                   @default(0)  // purchased top-ups — NEVER reset, spendable as general
  creditsResetAt              DateTime?                          // start of the current monthly cycle; null = never granted
  plan                        String                @default("BASIC") // BASIC, PRO, ULTRA
  savedJobs                   SavedJob[]
  jobAlerts                   JobAlert[]
  accounts                    Account[]
  applications                Application[]
  comments                    Comment[]
  commentVotes                CommentVote[]
  education                   Education[]
  experience                  Experience[]
  jobs                        Job[]                 @relation("RecruiterJobs")
  likes                       Like[]
  notifications               Notification[]
  triggeredNotifications      Notification[]        @relation("NotificationActor")
  pollVotes                   PollVote[]
  posts                       Post[]
  profileViews                ProfileView[]         @relation("ProfileViews")
  viewedProfiles              ProfileView[]         @relation("ViewedProfiles")
  projects                    Project[]
  reportsReceived             Report[]              @relation("ReportedUser")
  reportsFiled                Report[]              @relation("Reporter")
  sessions                    Session[]
  company                     Company?              @relation(fields: [companyId], references: [id])
  verificationRequests        VerificationRequest[]
  followers                   Follow[]              @relation("following")
  following                   Follow[]              @relation("follower")

  sentConnections     Connection[] @relation("SentConnections")
  receivedConnections Connection[] @relation("ReceivedConnections")

  // Messaging
  conversations ConversationParticipant[]
  messagesSent  Message[]
  interviews    Interview[]
  assessments   UserAssessment[]
  transactions  Transaction[]

  // 2FA & Settings Overhaul fields
  twoFactorEnabled     Boolean      @default(false)
  twoFactorSecret      String?      // encrypted TOTP secret (AES-256-GCM hex string)
  twoFactorBackupCodes String[]     // bcrypt-hashed backup codes
  twoFactorVerifiedAt  DateTime?    // last verified 2FA timestamp
  searchIndexable      Boolean      @default(true)
  openToWork           Boolean      @default(false)
  loginEvents          LoginEvent[] // access audit log
  verifiedSkills       VerifiedSkill[]
  savedSearches        SavedSearch[]         @relation("RecruiterSavedSearches")
  systemReports        SystemReport[]
  bookingsAsRecruiter  Booking[]      @relation("RecruiterBookings")
  bookingsAsCandidate  Booking[]      @relation("CandidateBookings")
  reposts              Repost[]
  endorsementsGiven    Endorsement[]  @relation("EndorsementsGiven")
  endorsementsReceived Endorsement[]  @relation("EndorsementsReceived")
}

model LoginEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  success   Boolean
  ipAddress String?
  userAgent String?
  location  String?
  createdAt DateTime @default(now())
}

model Interview {
  id         String   @id @default(uuid())
  userId     String
  role       String
  difficulty Int
  score      Int // 0-100
  feedback   String?  @db.Text
  radarData  Json? // Stores { technical: number, communication: number, ... }
  transcript Json? // Stores full chat history
  roleClassification Json?
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  telemetries InterviewTelemetry[]
}

// ... (previous content)

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  theme     String   @default("default")

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  userId         String
  conversationId String
  hasUnread      Boolean  @default(false)
  accepted       Boolean  @default(true) // false = pending message request for this participant
  lastReadAt     DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([userId, conversationId])
}

// ... (previous content)

model Message {
  id             String   @id @default(uuid())
  content        String?
  attachmentUrl  String?
  attachmentType String?
  senderId       String
  conversationId String
  createdAt      DateTime @default(now())

  // New Chat Features
  replyToId String?
  replyTo   Message?  @relation("ReplyRelation", fields: [replyToId], references: [id])
  replies   Message[] @relation("ReplyRelation")

  reactions Json? // Stores array of { userId: string, emoji: string }
  isDeleted Boolean @default(false)
  forwarded Boolean @default(false)

  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Connection {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING") // PENDING, ACCEPTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("SentConnections", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedConnections", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  link        String?
  imageUrl    String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String   @id @default(uuid())
  userId      String
  position    String
  company     String
  startDate   String
  endDate     String?
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Education {
  id           String   @id @default(uuid())
  userId       String
  school       String
  degree       String
  fieldOfStudy String?
  startDate    String?
  endDate      String?
  description  String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model VerificationRequest {
  id          String    @id @default(uuid())
  userId      String
  type        String    @default("IDENTITY")
  documentUrl String
  status      String    @default("PENDING")
  feedback    String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id             String   @id @default(uuid())
  reporterId     String
  reportedUserId String?
  targetType     String
  targetId       String?
  reason         String
  status         String   @default("PENDING")
  adminNotes     String?
  resolvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  category       String   @default("OTHER")
  severity       String   @default("LOW")
  // Reports pipeline (Phase 3): AI triage + admin↔user support thread.
  aiSummary      String?         @db.Text   // AI technical summary of the report
  fixPrompt      String?         @db.Text   // copy-paste coding-AI fix prompt
  threadStatus   String          @default("OPEN") // OPEN | CLOSED (admin closes the conversation)
  adminReadAt    DateTime?       // last time an admin opened/replied to this thread — drives unread badges
  reportedUser   User?    @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reporter       User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  messages       ReportMessage[]
}

model ReportMessage {
  id         String   @id @default(uuid())
  reportId   String
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  senderId   String   // user id of the author
  senderRole String   // 'ADMIN' | 'USER'
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@index([reportId])
}

model Notification {
  id           String  @id @default(uuid())
  userId       String
  type         String
  message      String
  resourcePath String?
  read         Boolean @default(false)

  actorId  String?
  entityId String?

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
}

model Post {
  id          String    @id @default(uuid())
  content     String
  image       String?
  codeSnippet String?
  tags        String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  type        String    @default("TEXT")
  comments    Comment[]
  likes       Like[]
  reposts     Repost[]
  views       PostView[]
  poll        Poll?
  author      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PostView {
  id       String   @id @default(uuid())
  postId   String
  viewerId String? // null = anonymous/logged-out view
  viewedAt DateTime @default(now())
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([postId, viewerId, viewedAt])
}

model Repost {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId]) // one repost per user per post (toggle)
  @@index([postId])
}

model Endorsement {
  id         String   @id @default(uuid())
  endorserId String
  userId     String // the endorsed user
  skill      String
  createdAt  DateTime @default(now())
  endorser   User     @relation("EndorsementsGiven", fields: [endorserId], references: [id], onDelete: Cascade)
  user       User     @relation("EndorsementsReceived", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([endorserId, userId, skill]) // one endorsement per skill per endorser
  @@index([userId])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String        @id @default(uuid())
  content   String
  postId    String
  userId    String
  createdAt DateTime      @default(now())
  parentId  String?
  parent    Comment?      @relation("CommentToComment", fields: [parentId], references: [id])
  replies   Comment[]     @relation("CommentToComment")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes     CommentVote[]
}

model CommentVote {
  id        String   @id @default(uuid())
  type      VoteType
  commentId String
  userId    String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model Poll {
  id        String       @id @default(uuid())
  postId    String       @unique
  question  String
  createdAt DateTime     @default(now())
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options   PollOption[]
  pollVotes PollVote[]
}

model PollOption {
  id          String     @id @default(uuid())
  text        String
  votes       Int        @default(0)
  pollId      String
  poll        Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votesRecord PollVote[]
}

model PollVote {
  id        String     @id @default(uuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime   @default(now())
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

model ProfileView {
  id        String   @id @default(uuid())
  viewerId  String
  profileId String
  viewedAt  DateTime @default(now())
  profile   User     @relation("ProfileViews", fields: [profileId], references: [id], onDelete: Cascade)
  viewer    User     @relation("ViewedProfiles", fields: [viewerId], references: [id], onDelete: Cascade)

  @@index([profileId, viewedAt])
  @@index([viewerId, profileId])
}

model Company {
  id          String   @id @default(uuid())
  name        String
  slug        String?  @unique // URL identifier for /company/[slug]
  logo        String?
  banner      String?
  tagline     String?
  website     String?
  description String?
  industry    String?
  location    String?
  foundedYear String?
  companySize String? // e.g. "50-100"
  techStack   String? // comma-separated, e.g. "Next.js,React,Postgres"
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  jobs        Job[]
  recruiters  User[]
}

model Job {
  id              String        @id @default(uuid())
  title           String
  location        String
  type            String        @default("Full-time") // Full-time, Contract, etc.
  workplaceType   String        @default("On-site") // On-site, Hybrid, Remote
  experienceLevel String        @default("Mid-Level") // Entry, Senior, Director
  salaryMin       Int?
  salaryMax       Int?
  currency        String        @default("USD")
  payPeriod       String        @default("Yearly")
  description     String
  skills          String // Stored as comma-separated or JSON
  applyMethod     String        @default("easy")
  externalUrl     String?
  questions       Json? // Screening questions
  userId          String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  status          String        @default("OPEN") // OPEN, CLOSED, DRAFT
  companyId       String
  applications    Application[]
  savedBy         SavedJob[]
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  recruiter       User          @relation("RecruiterJobs", fields: [userId], references: [id], onDelete: Cascade)
}

model Dictionary {
  id String @id @default(uuid())
  // Placeholder for global skills/locations if needed
}

model Application {
  id         String   @id @default(uuid())
  jobId      String
  userId     String
  status     String   @default("PENDING") // PENDING, REVIEWED, SHORTLISTED, REJECTED, HIRED
  matchScore Int?
  resumeUrl  String?
  answers    Json? // Answers to screening questions
  viewedAt   DateTime? // first time the recruiter opened this application (drives APPLICATION_VIEWED)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId]) // Prevent double applying
}

model SavedJob {
  id      String   @id @default(uuid())
  userId  String
  jobId   String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model JobAlert {
  id        String   @id @default(uuid())
  userId    String
  title     String // e.g. "Remote React Jobs"
  criteria  Json // Filters: { role: "Engineer", remote: true, minSalary: 100000 }
  frequency String   @default("DAILY") // DAILY, WEEKLY
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VoteType {
  UP
  DOWN
}

model Assessment {
  id              String           @id @default(uuid())
  title           String
  description     String
  category        String
  icon            String?
  questions       Question[]
  userAssessments UserAssessment[]
}

model Question {
  id           String     @id @default(uuid())
  text         String
  options      Json // Array of strings
  correctIndex Int
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model UserAssessment {
  id           String     @id @default(uuid())
  userId       String
  assessmentId String
  score        Int
  status       String // "PASSED" | "FAILED"
  attemptedAt  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int // in cents
  credits   Int
  currency  String   @default("USD")
  status    String // PENDING, COMPLETED, REJECTED
  provider  String   @default("PAYONEER")
  type      String   @default("CREDITS") // CREDITS, PLAN
  planName  String? // PRO, ULTRA
  refId     String? // Payoneer Transaction ID from user
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerifiedSkill {
  id             String       @id @default(uuid())
  userId         String
  skillId        String
  name           String       @default("")
  description    String       @default("")
  status         String       @default("VERIFIED")
  verifiedAt     DateTime     @default(now())
  depthScore     Int          @default(90)
  // The PASSING interview that earned this badge (issuance gate, 2026-06).
  // Nullable for legacy rows; the backfill links/revokes those.
  interviewId    String?
  skillDetailsId String?
  skillDetails   SkillDetail? @relation(fields: [skillDetailsId], references: [id], onDelete: SetNull)

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model SkillDetail {
  id             String          @id @default(uuid())
  verifiedSkills VerifiedSkill[]
}

// Recruiter saved talent searches — power "alert me when a new verified candidate
// matches" (fired when a badge is issued, see finalizeInterview).
model SavedSearch {
  id          String   @id @default(cuid())
  recruiterId String
  query       String
  createdAt   DateTime @default(now())
  lastAlertAt DateTime?

  recruiter   User     @relation("RecruiterSavedSearches", fields: [recruiterId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
}

model SystemReport {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  userWords   String   @db.Text       // Exactly what the user wrote
  category    String   @default("bug") // "bug" | "support" | "feature" | "stuck"
  aiSummary   String?  @db.Text       // AI technical summary
  fixPrompt   String?  @db.Text       // Copy-paste ready Antigravity prompt
  status      String   @default("OPEN") // "OPEN" | "ANALYZED" | "IN_PROGRESS" | "RESOLVED"
  severity    String   @default("medium") // "low" | "medium" | "high" | "critical"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InterviewTelemetry {
  id           String   @id @default(uuid())
  interviewId  String
  messageIndex Int
  confidence   Int
  topics       String[]
  feedback     String
  createdAt    DateTime @default(now())

  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, messageIndex])
}

// LinkedIn-style cancellation feedback collected when a user cancels their plan.
model CancellationFeedback {
  id        String   @id @default(cuid())
  userId    String
  plan      String
  reason    String
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// Interview booking between a recruiter and a candidate. The video meeting link
// (meetingUrl) is wired in a later phase — the rest of the lifecycle is handled here.
model Booking {
  id          String   @id @default(cuid())
  recruiterId String
  candidateId String
  jobId       String?
  status      String   @default("REQUESTED") // REQUESTED, CONFIRMED, DECLINED, CANCELLED, COMPLETED, EXPIRED, HIRED
  hiredAt     DateTime?                        // set when the recruiter marks the candidate hired (outcome loop)
  message     String?
  proposedAt  DateTime
  meetingUrl  String?
  // Candidate must accept before expiresAt (default createdAt + 7d, or recruiter-set);
  // accepting costs 1 General credit. acceptCostCharged guards against double-charge.
  expiresAt        DateTime?
  acceptCostCharged Boolean @default(false)
  reminderSentAt   DateTime?              // set once a BOOKING_REMINDER goes out (cron dedupe)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiter   User @relation("RecruiterBookings", fields: [recruiterId], references: [id], onDelete: Cascade)
  candidate   User @relation("CandidateBookings", fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([recruiterId])
  @@index([candidateId])
}

